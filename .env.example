# ─────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────
# LLM providers
# ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────
# Gmail OAuth (server-side client credentials)
# User access/refresh tokens come from Supabase Auth Google provider
# ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────
# Encryption key for user_email_credentials.refresh_token
# Generate: openssl rand -base64 32
# ─────────────────────────────────────────────────────────
EMAIL_TOKEN_ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────
# Framer (frontend) — only public values here
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
