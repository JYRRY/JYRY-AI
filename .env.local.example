# Copy to .env.local and fill in real values. This file is the canonical list
# of environment variables consumed by the Edge Functions during
# `supabase functions serve --env-file .env.local`.

# --- Claude / OpenAI ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Supabase (auto-set by `supabase start`; override only for remote dev) ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_ANON_KEY=...

# --- Google OAuth (for Gmail send + inbox polling) ---
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...

# --- Envelope encryption for refresh tokens in user_email_credentials ---
# Generate with: openssl rand -base64 32
EMAIL_TOKEN_ENCRYPTION_KEY=

# --- BCC archive address ---
# Every outgoing application email gets silently BCC'd here so JYRY keeps an
# authoritative copy independent of the user's personal Gmail. Any inbox works
# — a free @gmail.com account is fine (no Workspace licence needed).
# If unset, sends still succeed but nothing is archived (a warning is logged).
JYRY_ARCHIVE_EMAIL=archive.jyrygroup@gmail.com
